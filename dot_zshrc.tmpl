# Path (consolidated - no need for .deno/env and .local/bin/env)
export PATH="$HOME/.local/bin:$HOME/.deno/bin:$HOME/.juliaup/bin:$PATH"
export FPATH="$HOME/completions:$FPATH"

# Oh My Zsh
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="robbyrussell"
HYPHEN_INSENSITIVE="true"
zstyle ':omz:update' mode auto
zstyle ':omz:update' frequency 13
ENABLE_CORRECTION="true"
COMPLETION_WAITING_DOTS="true"
HIST_STAMPS="dd.mm.yyyy"
plugins=(git)

# Cache compinit - only regenerate once per day
zstyle ':omz:alpha:lib:completion' caching yes
source $ZSH/oh-my-zsh.sh
{{- if eq .distro "fedora" }}

sysup() {
  if [[ "$1" == "-r" || "$1" == "--release" ]]; then
    _sysup_release "$2"
    return $?
  fi
  command sudo -v || return 1
  ssh-add -l &>/dev/null || { ssh-add ~/.ssh/id_ed25519 || return 1; }
  setopt LOCAL_OPTIONS NO_NOTIFY NO_MONITOR
  local -a names=(dnf flatpak rustup deno npm dotfiles noson claude)
  local -a logs pids
  for n in $names; do logs+=($(mktemp)); done
  local start=$SECONDS
  command sudo dnf up -y &>"${logs[1]}" &
  pids+=($!)
  setsid flatpak upgrade -y &>"${logs[2]}" &
  pids+=($!)
  rustup update &>"${logs[3]}" &
  pids+=($!)
  deno upgrade &>"${logs[4]}" &
  pids+=($!)
  command sudo npm update -g --fund=false --loglevel=error &>"${logs[5]}" &
  pids+=($!)
  chezmoi update --no-tty &>"${logs[6]}" &
  pids+=($!)
  {
    local latest=$(curl -sf "https://api.github.com/repos/janbar/noson-app/releases/latest" | python3 -c "import sys,json; print(json.load(sys.stdin)['tag_name'])")
    local current=$(cat ~/Applications/.noson-version 2>/dev/null)
    if [[ -n "$latest" && "$latest" != "$current" ]]; then
      curl -Lf -o ~/Applications/noson.AppImage "https://github.com/janbar/noson-app/releases/download/${latest}/noson-${latest}-x86_64.AppImage" \
        && chmod +x ~/Applications/noson.AppImage \
        && echo "$latest" > ~/Applications/.noson-version \
        && echo "Updated: $current -> $latest"
    else
      echo "noson ${current:-unknown} is up to date"
    fi
  } &>"${logs[7]}" &
  pids+=($!)
  distrobox enter claude-desktop -- sh -c 'sudo apt-get update -q && sudo apt-get upgrade -y' &>"${logs[8]}" &
  pids+=($!)
  local lines=$(( ${#names} + 2 ))
  local spin='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏' i=0 drawn=0
  tput civis 2>/dev/null
  trap 'tput cnorm 2>/dev/null' INT TERM
  while true; do
    local all_done=1
    for j in {1..${#pids}}; do
      kill -0 ${pids[$j]} 2>/dev/null && all_done=0 && break
    done
    (( all_done )) && break
    (( drawn )) && printf "\033[${lines}A"
    local elapsed=$((SECONDS - start))
    local maxw=$(( COLUMNS - 16 ))
    local s=${spin:$((i%${#spin})):1}
    printf "\033[K\n"
    printf "\033[K  \033[1;33m%s\033[0m  \033[1msysup\033[0m  \033[2m%dm%02ds\033[0m\n" \
      "$s" $((elapsed/60)) $((elapsed%60))
    for j in {1..${#pids}}; do
      local last=$(tail -1 "${logs[$j]}" 2>/dev/null | sed 's/\x1b\[[0-9;]*m//g' | tr -d '\r')
      if kill -0 ${pids[$j]} 2>/dev/null; then
        printf "\033[K  \033[33m●\033[0m  %-8s \033[2m%s\033[0m\n" "${names[$j]}" "${${last:-(starting...)}:0:$maxw}"
      else
        printf "\033[K  \033[32m✓\033[0m  %-8s \033[2mdone\033[0m\n" "${names[$j]}"
      fi
    done
    printf "\033[K"
    drawn=1; ((i++)); sleep 0.5
  done
  tput cnorm 2>/dev/null
  trap - INT TERM
  if (( drawn )); then
    printf "\033[${lines}A"
    for _ in {1..$lines}; do printf "\033[K\n"; done
    printf "\033[${lines}A"
  fi
  wait
  for j in {1..${#names}}; do
    printf "\n\033[1;36m--- %s ---\033[0m\n" "${names[$j]}"; cat "${logs[$j]}"
  done
  rm -f "${logs[@]}"
  printf "\n\033[1;32m✓ Done in %ds\033[0m\n" "$((SECONDS - start))"
}

# garantierter Cleanup des temp. Swap-Puffers ($1 = pfad); idempotent
_sysup_relcleanup() {
  [[ -n "$1" && -e "$1" ]] || return 0
  command sudo swapoff "$1" 2>/dev/null
  command sudo rm -f "$1" && printf "\033[2m  temporärer Swap-Puffer entfernt\033[0m\n"
}

# Fedora Release-Upgrade (online distro-sync + Swap-Puffer gegen dnf5-RAM-Peak).
# Aufruf: sysup -r [zielversion]
_sysup_release() {
  emulate -L zsh
  local current target reply swapfile=/swapfile.sysup avail
  current=$(rpm -E %fedora)
  target="${1:-$((current + 1))}"

  printf "\033[1;36m▶ Fedora Release-Upgrade (online): %s → %s\033[0m\n" "$current" "$target"
  if (( target <= current )); then
    printf "\033[1;31m✗ Zielversion %s ist nicht neuer als die aktuelle (%s).\033[0m\n" "$target" "$current"
    return 1
  fi
  command sudo -v || return 1
  trap '_sysup_relcleanup "$swapfile"; trap - INT TERM' INT TERM

  # 0/4  Swap-Puffer – fängt den dnf5-Speicher-Peak ab (der hat F43→44 fast zerlegt)
  printf "\n\033[1;33m0/4\033[0m  Temporären 24G-Swap-Puffer anlegen…\n"
  avail=$(df --output=avail -BG / | tail -1 | tr -dc '0-9')
  [[ -e $swapfile ]] && { command sudo swapoff "$swapfile" 2>/dev/null; command sudo rm -f "$swapfile"; }
  if (( ${avail:-0} < 30 )); then
    printf "  \033[33m! nur %sG frei – überspringe Swap-Puffer (zram bleibt aktiv)\033[0m\n" "${avail:-0}"
  elif { command sudo btrfs filesystem mkswapfile --size 24g "$swapfile" 2>/dev/null \
         || { command sudo install -m600 /dev/null "$swapfile" && { command sudo chattr +C "$swapfile" 2>/dev/null; command sudo fallocate -l 24G "$swapfile" && command sudo mkswap "$swapfile" >/dev/null; }; }; } \
       && command sudo swapon "$swapfile" 2>/dev/null; then
    printf "  \033[32m✓\033[0m Swap-Puffer aktiv (24G)\n"
  else
    printf "  \033[33m! Swap-Puffer fehlgeschlagen (zram bleibt) – fahre fort\033[0m\n"
    command sudo rm -f "$swapfile"
  fi

  # 1/4  aktuelles System voll aktualisieren
  printf "\n\033[1;33m1/4\033[0m  System vollständig aktualisieren…\n"
  command sudo dnf upgrade --refresh -y \
    || { printf "\033[1;31m✗ Update fehlgeschlagen – abgebrochen.\033[0m\n"; _sysup_relcleanup "$swapfile"; trap - INT TERM; return 1; }

  # 2/4  Online-Release-Upgrade – dnf zeigt den Plan (inkl. Entfernungen), du bestätigst
  printf "\n\033[1;33m2/4\033[0m  Release-Upgrade auf Fedora %s — Plan prüfen & bestätigen:\n" "$target"
  free -h | awk 'NR==1 || /Mem:|Swap:/'
  command sudo dnf distro-sync --releasever="$target" --allowerasing \
    || { printf "\033[1;31m✗ Abgebrochen/fehlgeschlagen.\033[0m  Bei Duplikaten (nach Abbruch) notfalls dnf4:\n     sudo dnf4 distro-sync --releasever=%s --setopt='*.repo_gpgcheck=0' --allowerasing\n" "$target"; _sysup_relcleanup "$swapfile"; trap - INT TERM; return 1; }

  _sysup_relcleanup "$swapfile"
  trap - INT TERM

  # 3/4  Konsistenz prüfen
  printf "\n\033[1;33m3/4\033[0m  Konsistenz prüfen (dnf check)…\n"
  command sudo dnf check && printf "  \033[32m✓ keine Probleme\033[0m\n" \
    || printf "  \033[33m! dnf check meldet Punkte (siehe oben) – vor Reboot ansehen\033[0m\n"

  # 4/4  Reboot (Kernel-akmods bauen beim nächsten Boot neu)
  printf "\n\033[1;32m✓ Fedora %s angewendet.\033[0m\n" "$target"
  printf "\033[1;33m4/4\033[0m  Jetzt neu starten? [j/N] "
  read -k 1 reply; echo
  [[ "$reply" == [jJyY] ]] && command systemctl reboot \
    || printf "Später neu starten mit:  \033[1msystemctl reboot\033[0m\n"
}
{{- end }}
{{- if eq .distro "gentoo" }}

